model User {
  id           String    @id @default(cuid())
  name         String?
  phone        String    @unique
  email        String    @unique
  password     String
  nid          String?   @unique
  address      String?
  userType     UserRole  @default(INDIVIDUAL)
  
  companyName  String?
  officeEmail  String?   @unique
  isVerified   Boolean   @default(false)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // রিলেশনসমূহ
  nodes        Node[]    // এই লাইনটি নতুন যোগ হয়েছে

  referredById String?
  referredBy   User?     @relation("UserNetwork", fields: [referredById], references: [id])
  members      User[]    @relation("UserNetwork")
}

model Node {
  id        String   @id @default(cuid())
  type      NodeType @default(SCHOOL)
  title     String   
  year      String?  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}

enum UserRole {
  INDIVIDUAL
  COMPANY
}

enum NodeType {
  SCHOOL
  COLLEGE
  UNIVERSITY
  VILLAGE
  JOB
  OTHER
}