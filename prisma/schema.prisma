generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model District {
  id      String    @id
  name    String    @unique
  Upazila Upazila[]
}

model Hall {
  id            String      @id
  name          String
  institutionId String
  Institution   Institution @relation(fields: [institutionId], references: [id])
}

model Institution {
id            String       @id @default(cuid()) // এটি যোগ করুন
  name          String       @unique
  type       InsNodeType
  short_name String?
  location   String?
  district   String?
  config     Json?
  createdAt  DateTime    @default(now())
  updatedAt     DateTime     @updatedAt
  Hall       Hall[]
  Node       Node[]
}

model Node {
  id            String       @id @default(cuid())
  type          NodeType     @default(SCHOOL)
  title         String
  year          String?
  subject       String?
  metadata      Json?
  isPublic      Boolean      @default(true)
  isCommon      Boolean      @default(false)
  userId        String
  institutionId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt           // @updatedAt যোগ করুন
  Institution   Institution? @relation(fields: [institutionId], references: [id])
  User          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([title])
  @@index([type])
}

model NodeList {
 id        String  @id @default(cuid())
  name      String  @unique
  label     String
  category  String  @default("INDIVIDUAL")
  isDefault Boolean @default(false)
}

model Subject {
  id         String  @id
  name       String  @unique
  short_name String?
}

model Union {
  id        String  @id
  name      String
  upazilaId String
  Upazila   Upazila @relation(fields: [upazilaId], references: [id])
}

model Upazila {
  id         String   @id
  name       String
  districtId String
  Union      Union[]
  District   District @relation(fields: [districtId], references: [id])
}

model User {
  id           String   @id @default(cuid())
  name         String?
  phone        String   @unique
  email        String   @unique
  password     String
  nid          String?  @unique
  address      String?
  userType     UserRole @default(INDIVIDUAL)
  image        String?
  companyName  String?
  officeEmail  String?  @unique
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  referredById String?
  nodes        Node[]
  User         User?    @relation("UserToUser", fields: [referredById], references: [id])
  other_User   User[]   @relation("UserToUser")
}

enum InsNodeType {
  SCHOOL
  COLLEGE
  UNIVERSITY
  CADET_COLLEGE
  MEDICAL_COLLEGE
  MADRASA
  POLYTECHNIC
  MARINE_ACADEMY
  ARMY_INSTITUTE
}

enum NodeType {
  PR_ADDR
  PM_ADDR
  SCHOOL
  COLLEGE
  UNIVERSITY
  WORK_EXP
  SKILL
  BIO
  ORG_DIV
  ORG_DEPT
  ORG_SEC
  ORG_UNIT
  ORG_LINE
  ORG_DESIG
  OFFICE_LOC
  NOMINEE
  OTHER
}

enum UserRole {
  INDIVIDUAL
  COMPANY
}

model Organization {
  id          String   @id @default(cuid())
  name        String   @unique 
  industry    String   
  category    String?  
  logoUrl     String?  
  location    String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  experiences WorkExperience[]
  @@index([industry])
}

model WorkExperience {
  id             String    @id @default(cuid())
  userId         String    
  orgId          String    
  designation    String    
  desk           String?   
  employmentType String    @default("Full-time") 
  fromDate       DateTime
  toDate         DateTime? 
  isCurrent      Boolean   @default(false)
  expertise      String?   
  jobDetails     String?   @db.Text 
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  @@index([userId])
  @@index([orgId])
  @@index([designation])
}

model OrganizationStructure {
  id          String   @id @default(cuid())
  sector      String   // e.g., "Banking"
  orgName     String   // e.g., "Dutch-Bangla Bank PLC"
  department  String   // e.g., "IT Division"
  branch      String?  // e.g., "Head Office"
  
  @@index([sector])
  @@index([orgName])
}