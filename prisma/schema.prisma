generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  phone     String   @unique
  nid       String?  @unique
  address   String?
  createdAt DateTime @default(now())
  
  // Self-relation for Auto-Networking (Reference base)
  referredById String?
  referredBy   User?   @relation("UserNetwork", fields: [referredById], references: [id])
  members      User[]  @relation("UserNetwork")
}