// ১. প্রিজমা ক্লায়েন্ট জেনারেটর
generator client {
  provider = "prisma-client-js"
}

// ২. ডাটাবেজ কানেকশন (এখানে আপনার .env থেকে URL টি নিবে)
datasource db {
  provider = "postgresql" // আপনি যদি Neon বা অন্য Postgres ব্যবহার করেন
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String?
  phone        String    @unique
  email        String    @unique
  password     String
  nid          String?   @unique
  address      String?
  userType     UserRole  @default(INDIVIDUAL)
  image        String?
  companyName  String?
  officeEmail  String?   @unique
  isVerified   Boolean   @default(false)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // রিলেশনসমূহ
  nodes        Node[]    // এই লাইনটি নতুন যোগ হয়েছে

  referredById String?
  referredBy   User?     @relation("UserNetwork", fields: [referredById], references: [id])
  members      User[]    @relation("UserNetwork")
}

model Node {
  id        String   @id @default(cuid())
  type      NodeType @default(SCHOOL)
  title     String   
  year      String?  
  subject   String?  // নতুন ফিল্ড (Science/Arts/Commerce)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // --- নিচের দুটি লাইন যোগ করুন ---
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
  // ----------------------------
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}



enum UserRole {
  INDIVIDUAL
  COMPANY
}

enum NodeType {
  SCHOOL
  COLLEGE
  UNIVERSITY
  VILLAGE
  JOB
  OTHER
}

model NodeList {
  id    String @id @default(cuid())
  name  String @unique // যেমন: SCHOOL, COLLEGE, JOB, ইত্যাদি
  label String        // যেমন: School, College, Job, ইত্যাদি (ইউজার যা দেখবে)
}

// প্রতিষ্ঠানের মাস্টার লিস্ট (Autocomplete এর জন্য এখান থেকে ডেটা যাবে)
model Institution {
  id        String   @id @default(cuid())
  name      String   @unique
  type      NodeType // Enum: SCHOOL, COLLEGE, UNIVERSITY, CORPORATE
  district  String?
  nodes     Node[]   // ইউজারের প্রোফাইলের সাথে রিলেশন
}

// সাবজেক্ট বা ডিপার্টমেন্টের লিস্ট
model Subject {
  id    String @id @default(cuid())
  name  String @unique // যেমন: Computer Science, Accounting
}

// জেলার লিস্ট
model District {
  id         String    @id @default(cuid())
  name       String    @unique
  upazilas   Upazila[]
}

// উপজেলার লিস্ট
model Upazila {
  id         String   @id @default(cuid())
  name       String
  districtId String
  district   District @relation(fields: [districtId], references: [id])
}