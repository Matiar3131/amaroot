// ১. প্রিজমা ক্লায়েন্ট জেনারেটর
generator client {
  provider = "prisma-client-js"
}

// ২. ডাটাবেজ কানেকশন
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String?
  phone        String    @unique
  email        String    @unique
  password     String
  nid          String?   @unique
  address      String?
  userType     UserRole  @default(INDIVIDUAL)
  image        String?
  companyName  String?
  officeEmail  String?   @unique
  isVerified   Boolean   @default(false)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // রিলেশনসমূহ
  nodes        Node[]    

  referredById String?
  referredBy   User?     @relation("UserNetwork", fields: [referredById], references: [id])
  members      User[]    @relation("UserNetwork")
}

model Node {
  id            String   @id @default(cuid())
  type          NodeType @default(SCHOOL)
  title         String   // যেমন: "বড়খাতা উচ্চ বিদ্যালয়" বা "স্থায়ী ঠিকানা"
  year          String?  
  subject       String?  // Science/Arts/Commerce বা Dept
  
  // --- নতুন ফিল্ডসমূহ ---
  metadata      Json?    // বাসা নং, রোড, ইউনিয়ন, লিঙ্গ, ধর্ম সব এখানে থাকবে
  isPublic      Boolean  @default(true) // Hide/Show লজিক
  isCommon      Boolean  @default(false) // এটি কি কমন ফিল্ড (BIO/ADDR) নাকি ইউজার জেনারেটেড?
  // --------------------

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([title])
  @@index([type])
}

// NodeType এনামটি আপডেট করা হয়েছে সব টাইপ সাপোর্ট করার জন্য
enum NodeType {
  PR_ADDR
  PM_ADDR
  SCHOOL
  COLLEGE
  UNIVERSITY
  WORK_EXP
  SKILL
  BIO
  ORG_DIV
  ORG_DEPT
  ORG_SEC
  ORG_UNIT
  ORG_LINE
  ORG_DESIG
  OFFICE_LOC
  NOMINEE
  OTHER
}

model NodeList {
  id        String  @id @default(cuid())
  name      String  @unique 
  label     String 
  category  String  @default("INDIVIDUAL") // INDIVIDUAL বা CORPORATE আলাদা করার জন্য
  isDefault Boolean @default(false) 
}

model Institution {
  id        String   @id @default(cuid())
  name      String   @unique
  type      NodeType 
  district  String?
  nodes     Node[]   
}

// সাবজেক্ট বা ডিপার্টমেন্টের লিস্ট
model Subject {
  id    String @id @default(cuid())
  name  String @unique 
}

// জেলার লিস্ট
model District {
  id         String    @id @default(cuid())
  name       String    @unique
  upazilas   Upazila[]
}

// উপজেলার লিস্ট
model Upazila {
  id         String   @id @default(cuid())
  name       String
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  unions     Union[]
}

model Union {
  id        String   @id @default(cuid())
  name      String
  upazilaId String
  upazila   Upazila  @relation(fields: [upazilaId], references: [id])
}

enum UserRole {
  INDIVIDUAL
  COMPANY
}